{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "paths": {
      "@guildhall/agents": ["./src/agents/index.ts"],
      "@guildhall/backend-host": ["./src/backend-host/index.ts"],
      "@guildhall/compaction": ["./src/compaction/index.ts"],
      "@guildhall/config": ["./src/config/index.ts"],
      "@guildhall/core": ["./src/core/index.ts"],
      "@guildhall/engine": ["./src/engine/index.ts"],
      "@guildhall/hooks": ["./src/hooks/index.ts"],
      "@guildhall/levers": ["./src/levers/index.ts"],
      "@guildhall/mcp": ["./src/mcp/index.ts"],
      "@guildhall/protocol": ["./src/protocol/index.ts"],
      "@guildhall/providers": ["./src/providers/index.ts"],
      "@guildhall/runtime": ["./src/runtime/index.ts"],
      "@guildhall/runtime-bundle": ["./src/runtime-bundle/index.ts"],
      "@guildhall/sessions": ["./src/sessions/index.ts"],
      "@guildhall/skills": ["./src/skills/index.ts"],
      "@guildhall/tools": ["./src/tools/index.ts"]
    }
  },
  "include": ["src"]
}

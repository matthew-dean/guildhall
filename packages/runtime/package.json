{
  "name": "@guildhall/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "guildhall": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@guildhall/core": "workspace:*",
    "@guildhall/config": "workspace:*",
    "@guildhall/engine": "workspace:*",
    "@guildhall/tools": "workspace:*",
    "@guildhall/agents": "workspace:*",
    "@guildhall/skills": "workspace:*",
    "@guildhall/hooks": "workspace:*",
    "@guildhall/providers": "workspace:*",
    "@guildhall/compaction": "workspace:*",
    "@guildhall/protocol": "workspace:*",
    "@guildhall/backend-host": "workspace:*",
    "@guildhall/levers": "workspace:*",
    "@inquirer/prompts": "^7.4.0",
    "hono": "^4.7.7",
    "@hono/node-server": "^1.14.1",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^3.1.1"
  }
}

{
  "name": "@guildhall/runtime-bundle",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@guildhall/engine": "workspace:*",
    "@guildhall/hooks": "workspace:*",
    "@guildhall/protocol": "workspace:*",
    "@guildhall/sessions": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "@types/node": "^22.10.7"
  }
}
